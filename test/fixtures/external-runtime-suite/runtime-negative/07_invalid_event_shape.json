{
  "jsondeck": "0.1",
  "id": "runtime-invalid-event-shape",
  "title": "Runtime invalid event shapes",
  "description": "Compiles fine; dispatching malformed events (null, {}, { type: 123 }) must return INVALID_EVENT without throwing and without mutating state.",
  "table": {
    "width": 1280,
    "height": 720,
    "background": "#2f6b3f",
    "camera": { "mode": "fixed" }
  },
  "variables": {
    "flag": { "type": "boolean", "initial": false }
  },
  "zones": {
    "main_zone": {
      "title": "Main",
      "type": "free_space",
      "layout": "free",
      "rect": { "x": 0, "y": 0, "w": 1280, "h": 720 }
    }
  },
  "cardTypes": {
    "unit": {
      "title": "Unit",
      "tags": ["unit"],
      "props": { "power": 1 }
    }
  },
  "initialState": {
    "cards": [{ "id": "card_1", "type": "unit", "zone": "main_zone", "x": 100, "y": 100, "face": "up" }]
  },
  "rules": [
    {
      "id": "set_flag_on_click",
      "on": "card.clicked",
      "then": [{ "set_var": { "name": "flag", "value": true } }]
    }
  ],
  "hud": [],
  "theme": {
    "card": { "width": 120, "height": 170, "borderRadius": 12, "background": "#f4ead7", "textColor": "#1b1b1b" },
    "zone": { "border": "#ffffff55", "background": "#00000022" }
  }
}

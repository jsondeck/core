{
  "jsondeck": "0.1",
  "id": "runtime-move-card-bad-coordinate",
  "title": "Runtime move_card with non-number coordinate",
  "description": "move_card.x resolves to a string at runtime; the command must error and the whole rule transaction must roll back.",
  "table": {
    "width": 1280,
    "height": 720,
    "background": "#2f6b3f",
    "camera": { "mode": "fixed" }
  },
  "variables": {
    "marker": { "type": "number", "initial": 0 },
    "dest": { "type": "string", "initial": "zone_b" },
    "bad_x": { "type": "string", "initial": "oops" }
  },
  "zones": {
    "zone_a": {
      "title": "A",
      "type": "free_space",
      "layout": "free",
      "rect": { "x": 0, "y": 0, "w": 640, "h": 720 }
    },
    "zone_b": {
      "title": "B",
      "type": "table",
      "layout": "free",
      "rect": { "x": 640, "y": 0, "w": 640, "h": 720 }
    }
  },
  "cardTypes": {
    "unit": {
      "title": "Unit",
      "tags": ["unit"],
      "props": { "power": 1 }
    }
  },
  "initialState": {
    "cards": [{ "id": "card_1", "type": "unit", "zone": "zone_a", "x": 100, "y": 100, "face": "up" }]
  },
  "rules": [
    {
      "id": "move_with_bad_coordinate",
      "on": "card.clicked",
      "then": [
        { "modify_var": { "name": "marker", "add": 5 } },
        {
          "move_card": {
            "card": "$source",
            "to_zone": "$vars.dest",
            "x": "$vars.bad_x",
            "y": 10
          }
        }
      ]
    }
  ],
  "hud": [],
  "theme": {
    "card": { "width": 120, "height": 170, "borderRadius": 12, "background": "#f4ead7", "textColor": "#1b1b1b" },
    "zone": { "border": "#ffffff55", "background": "#00000022" }
  }
}

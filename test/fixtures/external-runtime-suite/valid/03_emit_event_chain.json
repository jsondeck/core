{
  "jsondeck": "0.1",
  "id": "emit-event-chain",
  "title": "Emit event chain",
  "table": {
    "width": 1280,
    "height": 720,
    "background": "#2f6b3f",
    "camera": {
      "mode": "fixed"
    }
  },
  "variables": {
    "total": {
      "type": "number",
      "initial": 0
    },
    "done": {
      "type": "boolean",
      "initial": false
    },
    "last": {
      "type": "string",
      "initial": "none"
    }
  },
  "zones": {
    "main_zone": {
      "title": "Main",
      "type": "free_space",
      "layout": "free",
      "rect": {
        "x": 0,
        "y": 0,
        "w": 1280,
        "h": 720
      }
    }
  },
  "cardTypes": {
    "unit": {
      "title": "Unit",
      "tags": [
        "unit"
      ],
      "props": {
        "power": 1
      }
    },
    "marker": {
      "title": "Marker",
      "tags": [
        "marker"
      ],
      "props": {
        "value": 1
      }
    }
  },
  "initialState": {
    "cards": [
      {
        "id": "card_1",
        "type": "unit",
        "zone": "main_zone",
        "x": 100,
        "y": 100,
        "face": "up"
      }
    ]
  },
  "rules": [
    {
      "id": "emit_step_one",
      "on": "game.started",
      "then": [
        {
          "emit_event": {
            "type": "custom.step_one",
            "payload": {
              "amount": 2,
              "label": "root",
              "fromVar": "$vars.last"
            }
          }
        }
      ]
    },
    {
      "id": "handle_step_one",
      "on": "custom.step_one",
      "if": {
        "eq": [
          "$event.payload.label",
          "root"
        ]
      },
      "then": [
        {
          "modify_var": {
            "name": "total",
            "add": "$event.payload.amount"
          }
        },
        {
          "set_var": {
            "name": "last",
            "value": "$event.payload.label"
          }
        },
        {
          "emit_event": {
            "type": "custom.step_two",
            "payload": {
              "amount": "$event.payload.amount",
              "label": "$event.payload.label"
            }
          }
        }
      ]
    },
    {
      "id": "handle_step_two",
      "on": "custom.step_two",
      "if": {
        "eq": [
          "$event.payload.label",
          "root"
        ]
      },
      "then": [
        {
          "modify_var": {
            "name": "total",
            "add": "$event.payload.amount"
          }
        },
        {
          "set_var": {
            "name": "done",
            "value": true
          }
        }
      ]
    }
  ],
  "hud": [
    {
      "id": "total",
      "label": "Total",
      "value": "$vars.total"
    },
    {
      "id": "done",
      "label": "Done",
      "value": "$vars.done"
    },
    {
      "id": "last",
      "label": "Last",
      "value": "$vars.last"
    }
  ],
  "theme": {
    "card": {
      "width": 120,
      "height": 170,
      "borderRadius": 12,
      "background": "#f4ead7",
      "textColor": "#1b1b1b"
    },
    "zone": {
      "border": "#ffffff55",
      "background": "#00000022"
    },
    "font": {
      "family": "system",
      "size": 16
    }
  }
}
